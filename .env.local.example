NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JS_KEY=your_kakao_js_key

# Local/staging key pair
ODSAY_API_KEY_DEV=your_local_odsay_api_key
ODSAY_WEB_ORIGIN_DEV=http://localhost:4000

# Optional fallback (legacy)
# ODSAY_API_KEY=your_odsay_api_key
# ODSAY_WEB_ORIGIN=http://localhost:4000

DAILY_ODSAY_BUDGET=15000
ODSAY_RPS_LIMIT=4

GEOCODE_CACHE_TTL_MIN=20160
ROUTE_CACHE_TTL_MIN=30
LANE_CACHE_TTL_MIN=1440
