NODE_ENV=production
PORT=4000
# Optional Postgres persistence for session decision analytics
DATABASE_URL=
# 프로덕션 프론트 도메인 필수(공유 링크가 samemeet.com에서 /api/share 를 부를 때 CORS)
ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,https://samemeet.com
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JS_KEY=your_kakao_js_key
# ODsay 키는 환경별 분리를 권장합니다.
# - local/dev: ODSAY_API_KEY_DEV, ODSAY_WEB_ORIGIN_DEV
# - production: ODSAY_API_KEY_PROD, ODSAY_WEB_ORIGIN_PROD
# 하위 호환을 위해 ODSAY_API_KEY / ODSAY_WEB_ORIGIN도 여전히 사용됩니다.
ODSAY_API_KEY_DEV=your_local_or_dev_odsay_api_key
ODSAY_WEB_ORIGIN_DEV=http://localhost:4000
ODSAY_API_KEY_PROD=your_release_odsay_api_key
ODSAY_WEB_ORIGIN_PROD=https://samemeet.com
ENABLE_SHIFT_TARGETS=true

# ODsay quota / guardrail
DAILY_ODSAY_BUDGET=15000
ODSAY_RPS_LIMIT=4

# Cache tuning
GEOCODE_CACHE_TTL_MIN=20160
ROUTE_CACHE_TTL_MIN=30
LANE_CACHE_TTL_MIN=1440
# Optional Redis (Railway) route cache
# - REDIS_URL 미설정 시 기존 메모리 캐시만 사용
REDIS_URL=
# Redis route 캐시 TTL(초) 권장: 3600~7200
REDIS_ROUTE_CACHE_TTL_SEC=3600
# Redis route 캐시 시간 버킷(분) 권장: 30~60
REDIS_ROUTE_CACHE_BUCKET_MIN=60

# Midpoint performance alerting (optional)
# p95가 임계치(ms)를 넘으면 서버 로그 경고를 남깁니다.
MIDPOINT_P95_WARN_MS=8000
# Slack/Discord 등 Incoming Webhook URL (비워두면 로그 경고만 출력)
MIDPOINT_ALERT_WEBHOOK_URL=
# 경고 전송 쿨다운(ms): 기본 10분
MIDPOINT_ALERT_COOLDOWN_MS=600000
