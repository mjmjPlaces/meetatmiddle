NODE_ENV=production
PORT=4000
ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JS_KEY=your_kakao_js_key
# ODsay 키는 환경별 분리를 권장합니다.
# - local/dev: ODSAY_API_KEY_DEV, ODSAY_WEB_ORIGIN_DEV
# - production: ODSAY_API_KEY_PROD, ODSAY_WEB_ORIGIN_PROD
# 하위 호환을 위해 ODSAY_API_KEY / ODSAY_WEB_ORIGIN도 여전히 사용됩니다.
ODSAY_API_KEY_DEV=your_local_or_dev_odsay_api_key
ODSAY_WEB_ORIGIN_DEV=http://localhost:4000
ODSAY_API_KEY_PROD=your_release_odsay_api_key
ODSAY_WEB_ORIGIN_PROD=https://samemeet.com

# ODsay quota / guardrail
DAILY_ODSAY_BUDGET=15000
ODSAY_RPS_LIMIT=4

# Cache tuning
GEOCODE_CACHE_TTL_MIN=20160
ROUTE_CACHE_TTL_MIN=30
LANE_CACHE_TTL_MIN=1440
