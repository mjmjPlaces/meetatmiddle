{
  "name": "midpoint-transit-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "node --enable-source-maps dist/server/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test:odsay": "node scripts/test-odsay.js",
    "test:ab-shift": "node --import tsx scripts/ab-shift-check.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
